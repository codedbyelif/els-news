# ELS News — Ortam değişkenleri
# Bu dosyayı ".env.local" olarak kopyala ve değerleri Supabase panelinden doldur.

# Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Supabase → Project Settings → API → service_role (gizli! sadece sunucuda kullanılır)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Oturum çerezini imzalamak için uzun, rastgele bir metin.
# Üretmek için:  openssl rand -hex 32
SESSION_SECRET=buraya-uzun-rastgele-bir-metin-yaz
